{
  "name": "api-tape",
  "version": "0.2.1",
  "description": "Record real API responses as test fixtures. Auto-generate types, MSW handlers, and detect API drift.",
  "type": "module",
  "main": "src/index.js",
  "files": [
    "src/",
    "templates/"
  ],
  "bin": {
    "apitape": "src/cli/index.js"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "test-fixtures",
    "api-recording",
    "api-testing",
    "msw",
    "mock-data",
    "typescript",
    "api-drift",
    "snapshot-testing",
    "openapi"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Dan Li",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nbnd-z/apitape"
  },
  "bugs": {
    "url": "https://github.com/nbnd-z/apitape/issues"
  },
  "homepage": "https://github.com/nbnd-z/apitape#readme",
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "prettier": "^3.2.0"
  }
}
